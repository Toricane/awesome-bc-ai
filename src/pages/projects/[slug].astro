---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Generate accent class string based on category
const getAccentClass = (category: string) => {
  switch(category) {
    case 'Hackathons & Sprints': return 'text-brand-primary border-brand-primary bg-brand-primary/10';
    case 'Creative & Physical Modalities': return 'text-accent-creative border-accent-creative bg-accent-creative/10';
    case 'Open Data & Community Archives': return 'text-accent-ethical border-accent-ethical bg-accent-ethical/10';
    case 'Ecosystem Tooling & Infra': return 'text-accent-tooling border-accent-tooling bg-accent-tooling/10';
    default: return 'text-slate-400 border-slate-700 bg-slate-800';
  }
};

const getTextColor = (category: string) => {
  switch(category) {
    case 'Hackathons & Sprints': return 'text-brand-primary';
    case 'Creative & Physical Modalities': return 'text-accent-creative';
    case 'Open Data & Community Archives': return 'text-accent-ethical';
    case 'Ecosystem Tooling & Infra': return 'text-accent-tooling';
    default: return 'text-slate-300';
  }
};

const accentClass = getAccentClass(project.data.category);
const textColor = getTextColor(project.data.category);
---

<Layout title={project.data.title} category={project.data.category}>
	<div class="max-w-4xl mx-auto">
		<header class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <a href={`${import.meta.env.BASE_URL}directory`} class="text-sm text-slate-400 hover:text-white transition-colors">&larr; Back to Directory</a>
        <span class={`px-3 py-1 text-xs font-semibold rounded-full border ${accentClass}`}>
          {project.data.category}
        </span>
      </div>

			<h1 class={`text-4xl md:text-5xl font-bold font-display tracking-tight mb-4 ${textColor}`}>
				{project.data.title}
			</h1>
			
			<p class="text-xl text-slate-300 mb-8 border-l-2 border-slate-700 pl-4">
				{project.data.description}
			</p>

      <div class="flex flex-wrap items-center gap-6 pb-8 border-b border-slate-700/50">
        <div class="flex items-center gap-3">
          {project.data.author_github ? (
            <img 
              src={`https://github.com/${project.data.author_github.replace('@', '')}.png`} 
              alt={project.data.author_github} 
              class="w-12 h-12 rounded-full border border-slate-600"
            />
          ) : (
            <div class="w-12 h-12 rounded-full border border-slate-600 bg-slate-700 flex items-center justify-center text-slate-300 font-bold text-lg">
              {project.data.author_name.charAt(0).toUpperCase()}
            </div>
          )}
          <div>
            <p class="text-sm text-slate-400">Created by</p>
            {project.data.author_github ? (
              <a href={`https://github.com/${project.data.author_github.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="font-medium text-white hover:underline decoration-slate-500 underline-offset-4">
                {project.data.author_name} (@{project.data.author_github.replace('@', '')})
              </a>
            ) : (
              <p class="font-medium text-white">{project.data.author_name}</p>
            )}
          </div>
        </div>

        <div class="flex gap-3 ml-auto">
          {project.data.github_repo && (
            <a href={project.data.github_repo} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg border border-slate-600 bg-slate-800 text-sm font-medium hover:bg-slate-700 transition-colors flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
              GitHub Repo
            </a>
          )}
          {project.data.demo_url && (
            <a href={project.data.demo_url} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-slate-100 text-slate-900 text-sm font-bold hover:bg-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              Live Demo
            </a>
          )}
        </div>
      </div>
		</header>

		<article class="prose prose-invert prose-slate max-w-none prose-headings:font-display prose-a:text-brand-primary hover:prose-a:text-lime-300">
      {project.data.image && (
        <Image src={project.data.image} alt={project.data.title} class="w-full h-auto rounded-xl mt-8 mb-12 shadow-lg border border-slate-700" />
      )}
			<Content />
		</article>

    <footer class="mt-16 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h3 class="text-sm font-medium text-slate-400 mb-2">Tags</h3>
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map(tag => (
              <a href={`${import.meta.env.BASE_URL}directory?tag=${encodeURIComponent(tag)}`} class="px-3 py-1 text-xs rounded bg-slate-800 text-slate-300 hover:bg-slate-700 hover:text-white transition-colors">
                #{tag}
              </a>
            ))}
          </div>
        </div>
        
        {project.data.event && (
          <div class="text-right">
            <h3 class="text-sm font-medium text-slate-400 mb-2">Event</h3>
            <a href={`${import.meta.env.BASE_URL}events/${encodeURIComponent(project.data.event)}`} class="inline-block px-4 py-2 text-sm rounded bg-slate-800/50 border border-slate-700 text-slate-200 hover:bg-slate-800 transition-colors">
              {project.data.event}
            </a>
          </div>
        )}
      </div>
    </footer>
	</div>
</Layout>

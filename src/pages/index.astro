---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const categories = [
  { name: 'Hackathons & Sprints', accent: 'text-brand-primary border-brand-primary', description: 'Where caffeine meets code. Explore the R&D engines of our community, featuring tools and prototypes built during intensive two-month hackathons and collaborative build nights.' },
  { name: 'Creative & Physical Modalities', accent: 'text-accent-creative border-accent-creative', description: 'AI beyond the screen. A showcase of multi-modal art, autonomous hardware builds, AI Film Club cinematic experiments, and physical installations.' },
  { name: 'Open Data & Community Archives', accent: 'text-accent-ethical border-accent-ethical', description: 'Knowledge belongs to the collective. Dive into open-source datasets, meetup transcripts, and research aimed at keeping AI out of corporate silos.' },
  { name: 'Ecosystem Tooling & Infra', accent: 'text-accent-tooling border-accent-tooling', description: 'The digital roots that keep our network thriving. Discover the custom bots, workflow automations, and scripts built by volunteers to sustain the Braintrust.' }
];
---

<Layout title="Home">
	<section class="py-20 flex flex-col items-center justify-center text-center px-4">
		<div class="inline-block mb-4 px-3 py-1 rounded-full border border-slate-700 bg-slate-800/50 backdrop-blur-md text-sm text-slate-300 font-medium">
			No Gatekeepers. Just Builders.
		</div>
		<h1 class="text-5xl md:text-7xl font-bold font-display tracking-tight text-white mb-6">
			Awesome <br/>
			<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-accent-creative">BC + AI Ecosystem</span>
		</h1>
		<p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">
			An open, static directory for discovering the incredible projects, archives, and tools being built across British Columbia.
		</p>
		<div class="flex gap-4 justify-center">
			<a href={`${import.meta.env.BASE_URL}directory`} class="px-8 py-3 rounded-lg bg-brand-primary text-slate-900 font-bold hover:bg-lime-300 transition-colors shadow-[0_0_20px_rgba(163,230,53,0.3)]">
				Explore Directory
			</a>
			<a href={`${import.meta.env.BASE_URL}add`} class="px-8 py-3 rounded-lg border border-slate-700 bg-slate-800 text-white font-medium hover:bg-slate-700 transition-colors">
				Submit Project
			</a>
		</div>
	</section>

	<section class="max-w-4xl mx-auto px-4 md:px-8 mb-20 text-center">
		<div class="p-8 md:p-12 rounded-2xl border border-brand-primary/20 bg-slate-800/40 backdrop-blur-sm shadow-[0_0_30px_rgba(163,230,53,0.05)]">
			<h2 class="text-3xl font-bold font-display text-white mb-4">Built by the Community, for the Community.</h2>
			<p class="text-lg text-slate-300 leading-relaxed">
				We are British Columbia's grassroots AI collective. We believe in DIY over gatekeepers, community before clout, and building a future where artificial intelligence serves culture, creativity, and the planet. This directory is a living archive of our radically local, ethically bold approach to AI.
			</p>
		</div>
	</section>

	<div class="space-y-16 pb-20">
		{categories.map(category => {
			const categoryProjects = projects.filter(p => p.data.category === category.name);
			if (categoryProjects.length === 0) return null;

			return (
				<section class="px-4 md:px-8">
					<div class="mb-8">
						<div class="flex items-center justify-between mb-3">
							<h2 class={`text-2xl md:text-3xl font-bold font-display flex items-center gap-3`}>
								<span class={`w-2 h-8 rounded-full bg-current ${category.accent}`}></span>
								{category.name}
							</h2>
							<a href={`${import.meta.env.BASE_URL}directory?category=${encodeURIComponent(category.name)}`} class="text-sm text-slate-400 hover:text-white transition-colors">View All &rarr;</a>
						</div>
						<p class="text-slate-400 max-w-3xl ml-5 border-l-2 border-slate-700/50 pl-4 py-1 text-sm md:text-base">{category.description}</p>
					</div>
					
					<div class="flex overflow-x-auto gap-6 pb-8 snap-x snap-mandatory scrollbar-hide" style="scrollbar-width: none;">
						{categoryProjects.map(project => (
							<a href={`${import.meta.env.BASE_URL}projects/${project.id}`} class="snap-start flex-none w-[300px] md:w-[400px] group block">
								<div class={`h-full border border-slate-800 bg-slate-800/40 rounded-xl p-6 backdrop-blur-sm transition-all duration-300 hover:bg-slate-800 hover:-translate-y-1 hover:shadow-lg ${category.accent.replace('text-', 'hover:border-').replace('text-', 'hover:shadow-')}`}>
									<div class="flex items-center gap-3 mb-4">
										{project.data.author_github ? (
											<img 
												src={`https://github.com/${project.data.author_github.replace('@', '')}.png`} 
												alt={project.data.author_github} 
												class="w-10 h-10 rounded-full border border-slate-700"
											/>
										) : (
											<div class="w-10 h-10 rounded-full border border-slate-700 bg-slate-700 flex items-center justify-center text-slate-300 font-bold">
												{project.data.author_name.charAt(0).toUpperCase()}
											</div>
										)}
										<div class="text-sm">
											<p class="text-slate-300 font-medium">{project.data.author_name}</p>
											{project.data.author_github && (
												<p class="text-slate-500 text-xs">@{project.data.author_github.replace('@', '')}</p>
											)}
										</div>
									</div>
									<h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-primary transition-colors">{project.data.title}</h3>
									<p class="text-slate-400 text-sm line-clamp-3">{project.data.description}</p>
									<div class="mt-6 flex flex-wrap gap-2">
										{project.data.tags.map(tag => (
											<span class="px-2 py-1 text-xs rounded bg-slate-700/50 text-slate-300">#{tag}</span>
										))}
									</div>
								</div>
							</a>
						))}
					</div>
				</section>
			);
		})}
	</div>

	<section class="max-w-4xl mx-auto px-4 md:px-8 pb-20 text-center">
		<div class="p-10 md:p-16 rounded-3xl border border-indigo-500/30 bg-gradient-to-br from-indigo-900/40 to-purple-900/20 backdrop-blur-md shadow-2xl relative overflow-hidden">
			<div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
			<div class="relative z-10">
				<h2 class="text-3xl md:text-4xl font-bold font-display text-white mb-6">The code lives here. The community lives on Discord.</h2>
				<p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
					Want to collaborate on a build, join a working group like the AI Film Club, or just talk shop? The Braintrust is always open.
				</p>
				<a href="https://discord.gg/vwZzFHpWQ8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold text-lg transition-all hover:scale-105 shadow-[0_0_20px_rgba(88,101,242,0.4)]">
					<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
					Join the BC + AI Discord
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hide scrollbar for Chrome, Safari and Opera */
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
</style>

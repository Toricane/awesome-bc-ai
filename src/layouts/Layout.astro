---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	category?: 'Hackathons & Sprints' | 'Open Data & Community Archives' | 'Ecosystem Tooling & Infra' | 'Creative & Physical Modalities' | undefined;
}

const { title, category } = Astro.props;

let accentClass = 'border-slate-800 shadow-none';
let textAccentClass = 'text-brand-primary';

if (category === 'Hackathons & Sprints') {
	accentClass = 'border-brand-primary shadow-[0_0_15px_rgba(163,230,53,0.3)]';
	textAccentClass = 'text-brand-primary';
} else if (category === 'Creative & Physical Modalities') {
	accentClass = 'border-accent-creative shadow-[0_0_15px_rgba(6,182,212,0.3)]';
	textAccentClass = 'text-accent-creative';
} else if (category === 'Open Data & Community Archives') {
	accentClass = 'border-accent-ethical shadow-[0_0_15px_rgba(16,185,129,0.3)]';
	textAccentClass = 'text-accent-ethical';
} else if (category === 'Ecosystem Tooling & Infra') {
	accentClass = 'border-accent-tooling shadow-[0_0_15px_rgba(249,115,22,0.3)]';
	textAccentClass = 'text-accent-tooling';
}

const isProjectPage = !!category;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Awesome BC + AI</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="bg-slate-900 text-slate-200 font-sans min-h-screen flex flex-col selection:bg-brand-primary selection:text-slate-900">
		<div class="fixed inset-0 z-[-1] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-800 via-slate-900 to-slate-900 opacity-60"></div>
		
		<header class="border-b border-slate-800 bg-slate-900/50 backdrop-blur-md sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<a href={import.meta.env.BASE_URL} class="text-xl font-bold font-display tracking-tight flex items-center gap-2 group">
					<span class="text-brand-primary group-hover:drop-shadow-[0_0_8px_rgba(163,230,53,0.8)] transition-all">BC + AI</span>
					<span class="text-slate-400 font-light">Ecosystem</span>
				</a>
				<nav class="flex items-center gap-6">
					<a href={`${import.meta.env.BASE_URL}directory`} class="text-sm font-medium text-slate-300 hover:text-white transition-colors">Directory</a>
					<a href={`${import.meta.env.BASE_URL}add`} class="text-sm font-medium bg-brand-primary/10 text-brand-primary border border-brand-primary/30 px-3 py-1 rounded-full hover:bg-brand-primary hover:text-slate-900 transition-all shadow-[0_0_10px_rgba(163,230,53,0.1)] hover:shadow-[0_0_15px_rgba(163,230,53,0.4)]">Add Project</a>
				</nav>
			</div>
		</header>

		<main class="flex-grow flex flex-col pt-8 pb-20">
			<div class={`flex-grow mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 ${isProjectPage ? `border-t-4 transition-all duration-500 rounded-t-xl bg-slate-800/20 backdrop-blur-sm p-8 ${accentClass}` : ''}`}>
				<slot />
			</div>
		</main>

		<footer class="border-t border-slate-800 bg-slate-900 py-8 text-center text-slate-500 text-sm">
			<p>A community-driven directory for the BC + AI Ecosystem.</p>
		</footer>
	</body>
</html>

<style>
	:root {
		--font-sans: 'Outfit', sans-serif;
		--font-display: 'Space Grotesk', sans-serif;
	}
	body {
		font-family: var(--font-sans);
	}
	h1, h2, h3, h4, h5, h6, .font-display {
		font-family: var(--font-display);
	}
</style>
